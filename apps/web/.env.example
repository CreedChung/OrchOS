# Public client-side variables exposed to the browser.
# Leave empty in local dev to use the current page host with backend port 5173,
# which works for localhost and LAN access like http://100.x.x.x:3000.
VITE_API_BASE_URL=

# Enable realtime websocket updates explicitly when the backend websocket route
# is available in your current environment.
VITE_ENABLE_WEBSOCKET=false

# Server-only variables.
CLERK_JWT_KEY=
