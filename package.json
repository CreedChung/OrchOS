\{
  "name": "my-turborepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:all": "turbo run dev",
    "lint": "oxlint . --config .oxlintrc.json --ignore-path .gitignore",
    "lint:strict": "oxlint . --config .oxlintrc.json --ignore-path .gitignore --deny-warnings",
    "format": "oxfmt --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11"
}
